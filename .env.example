# Runtime mode — safe defaults
EXECUTION_MODE=paper
ENABLE_LIVE_TRADING=false
LEGAL_GATE_STATUS=NOT_APPROVED
CREDENTIAL_SOURCE=none
PROVIDER_ID=
LEGAL_APPROVAL_FILE=./.local/legal-gate.local.json

# Product limits
MAX_STAKE_PER_ORDER=5
MAX_MARKET_EXPOSURE=25
ENABLE_ONE_CLICK=false
ENABLE_MARKETABLE_ORDERS=false

# Polymarket read-only endpoints
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
POLYMARKET_GAMMA_HOST=https://gamma-api.polymarket.com
POLYMARKET_FALLBACK_MARKET_ID=
POLYMARKET_FALLBACK_CONDITION_ID=
POLYMARKET_FALLBACK_TOKEN_ID=
POLYMARKET_FALLBACK_OUTCOME=
PROVIDER_DATA_STALE_AFTER_MS=10000
PROVIDER_POLL_INTERVAL_MS=5000

# Kalshi read-only endpoints must be validated from official docs before adapter work.
KALSHI_API_HOST=
KALSHI_FALLBACK_MARKET_TICKER=
KALSHI_FALLBACK_OUTCOME=

# Polymarket authenticated trading credentials
# Default is CREDENTIAL_SOURCE=none, so live trading remains blocked.
# For a controlled local smoke test, copy .env.local-smoke.example locally and keep secrets outside git.
POLY_CHAIN_ID=137

# Legal / geo gate
TARGET_JURISDICTION=
BLOCK_LIVE_IF_GEO_UNKNOWN=true
BLOCK_LIVE_IF_PLATFORM_GEOBLOCKS=true

# Monetization / paid routing - DISABLED BY DEFAULT.
# Usage fees, provider attribution, broker fees, builder fees, and revenue share require explicit approval + fee disclosure.
ENABLE_PAID_ROUTING=false
PAID_ROUTING_DISCLOSURE_REQUIRED=true
MONETIZATION_MODE=free

# Audit log
AUDIT_LOG_DIR=./.local/audit
