# Controlled local smoke-test override example.
# Copy to .env.local only in a private local environment. Do not commit real secrets.

EXECUTION_MODE=paper
ENABLE_LIVE_TRADING=false
LEGAL_GATE_STATUS=NOT_APPROVED
CREDENTIAL_SOURCE=local_env_dev_only
PROVIDER_ID=polymarket

# Generic local dev/smoke secret consumed by provider-specific credential adapters.
LOCAL_DEV_PROVIDER_SECRET_LOCAL_DEV_ONLY=

# Optional provider-specific local values, only if the selected adapter needs them.
POLY_API_KEY_LOCAL_DEV_ONLY=
POLY_API_SECRET_LOCAL_DEV_ONLY=
POLY_API_PASSPHRASE_LOCAL_DEV_ONLY=
POLY_FUNDER_ADDRESS_LOCAL_DEV_ONLY=
POLY_CHAIN_ID=137
KALSHI_API_KEY_LOCAL_DEV_ONLY=
KALSHI_API_SECRET_LOCAL_DEV_ONLY=

LEGAL_APPROVAL_FILE=./.local/legal-gate.local.json
